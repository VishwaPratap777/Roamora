# Roamora — Environment Variables
# Copy this file to .env.local and fill in your API keys

# ──────────────────────────────────────────
# AI Providers
# ──────────────────────────────────────────

# OpenAI API Key (Primary AI — GPT-4o)
VITE_OPENAI_API_KEY=
OPENAI_API_KEY=

# Groq API Key (Backup AI — Llama 3)
VITE_GROQ_API_KEY=
GROQ_API_KEY=

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────

# MongoDB Atlas Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/roamora?retryWrites=true&w=majority

# ──────────────────────────────────────────
# Authentication (Clerk)
# ──────────────────────────────────────────

# Clerk Publishable Key (frontend — starts with pk_)
VITE_CLERK_PUBLISHABLE_KEY=

# Clerk Secret Key (backend — starts with sk_)
CLERK_SECRET_KEY=

# ──────────────────────────────────────────
# Maps
# ──────────────────────────────────────────

# Mapbox Access Token (for interactive maps)
VITE_MAPBOX_ACCESS_TOKEN=

# ──────────────────────────────────────────
# Other APIs
# ──────────────────────────────────────────

# OpenWeather API Key (for weather data)
VITE_OPENWEATHER_API_KEY=

# Google OAuth Client ID (legacy, replaced by Clerk)
# VITE_GOOGLE_CLIENT_ID=

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────

# Application URL
VITE_APP_URL=http://localhost:5173

# Server Port (development only)
PORT=3001
