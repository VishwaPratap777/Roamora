# Roamora Server — Environment Variables
# Copy this file to .env and fill in your API keys

# ──────────────────────────────────────────
# AI Providers
# ──────────────────────────────────────────

# OpenAI API Key (Primary AI — GPT-4o)
OPENAI_API_KEY=sk-...

# Groq API Key (Fallback AI — Llama 3)
GROQ_API_KEY=gsk_...

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────

# MongoDB Atlas Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/roamora?retryWrites=true&w=majority

# ──────────────────────────────────────────
# Authentication (Clerk)
# ──────────────────────────────────────────

# Clerk Secret Key (backend — starts with sk_)
CLERK_SECRET_KEY=

# Clerk Publishable Key
CLERK_PUBLISHABLE_KEY=

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────

PORT=3001
